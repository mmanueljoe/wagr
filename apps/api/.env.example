# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Upstash Redis (USSD session storage)
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-token

# Moolre — see docs/architecture/moolre-api-reference.md
# Account-level keys (one per business account):
MOOLRE_BASE_URL=https://sandbox.moolre.com
MOOLRE_API_USER=your-moolre-username
MOOLRE_API_KEY=your-private-key      # Transfers + Account
MOOLRE_API_PUBKEY=your-public-key    # Payments
MOOLRE_ACCOUNT_NUMBER=your-moolre-account-number
MOOLRE_WEBHOOK_SECRET=your-webhook-secret-from-account-update-response

# VAS keys — one per service instance generated in the Moolre dashboard.
# Both go in the same X-API-VASKEY header, different values per endpoint.
MOOLRE_SMS_VASKEY=your-sms-service-vas-key
MOOLRE_WHATSAPP_VASKEY=your-whatsapp-service-vas-key

# Generative AI (payslip-gpt, credit-scoring-gpt). Currently Google Gemini —
# get a key for free at https://aistudio.google.com (no credit card required).
GEMINI_API_KEY=your-gemini-api-key

# Web app origin (used for CORS). Defaults to http://localhost:3000 in dev.
WEB_URL=http://localhost:3000

# Sentry — leave blank in dev; required in prod
# SENTRY_DSN=

# Reconciler — runs both the advance and float-top-up reconcilers on
# the same timer. See apps/api/src/lib/advance-reconciler.ts +
# apps/api/src/lib/float-topup-reconciler.ts.
#
# Shared:
#   RECONCILER_INTERVAL_MS — how often the timer fires (default 5 min)
#
# Advance reconciler (money OUT — worker advances via Moolre Transfers):
#   RECONCILER_STUCK_AFTER_MS — advance pending longer than this gets
#                               re-polled (default 90s)
#   RECONCILER_FORCE_FAIL_AFTER_MS — past this age we give up on Moolre,
#                                    refund the float, SMS worker (default 24h)
#
# Float top-up reconciler (money IN — employer pre-funding via Moolre Payments).
# Payments uses webhooks instead of polling, so we can only force-fail past
# the timeout — no proactive status check.
#   FLOAT_TOPUP_RECONCILER_STUCK_AFTER_MS — top-up pending longer than this
#                                           is a candidate (default 60s)
#   FLOAT_TOPUP_RECONCILER_FORCE_FAIL_AFTER_MS — past this age we mark it
#                                                failed (default 1h)
#
# Tune these down for local testing to see the reconciler act quickly.
# RECONCILER_INTERVAL_MS=300000
# RECONCILER_STUCK_AFTER_MS=90000
# RECONCILER_FORCE_FAIL_AFTER_MS=86400000
# FLOAT_TOPUP_RECONCILER_STUCK_AFTER_MS=60000
# FLOAT_TOPUP_RECONCILER_FORCE_FAIL_AFTER_MS=3600000
