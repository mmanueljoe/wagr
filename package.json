{
  "name": "wagr",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Earned-wage-access platform for Ghanaian SME workers. Don't wait for payday.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:ussd-sim": "pnpm --filter api test:ussd-sim",
    "db:link": "pnpm dlx supabase link",
    "db:push": "pnpm dlx supabase db push",
    "db:types": "pnpm dlx supabase gen types typescript --linked > packages/types/src/supabase.ts",
    "db:seed": "pnpm --filter @wagr/api db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "turbo": "^2.10.0",
    "typescript": "^5.7.2"
  }
}
